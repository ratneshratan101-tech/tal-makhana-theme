{%- assign current_variant = product.selected_or_first_available_variant -%}

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
  <div class="breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="breadcrumb__sep">&rsaquo;</span>
    {%- if collection -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="breadcrumb__sep">&rsaquo;</span>
    {%- else -%}
      <a href="/collections/all">Shop</a>
      <span class="breadcrumb__sep">&rsaquo;</span>
    {%- endif -%}
    <span class="breadcrumb__current">{{ product.title }}</span>
  </div>
</div>

<!-- Product Hero -->
<div class="product-hero">

  <!-- Gallery -->
  <div class="gallery">
    <div class="gallery__main js-gallery-main">
      <div class="gallery__main-bg" aria-hidden="true"></div>
      <span class="gallery__badge">FSSAI Certified</span>
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 600 }}"
             alt="{{ product.featured_image.alt | default: product.title }}"
             loading="eager"
             id="gallery-main-img">
      {%- else -%}
        <span class="js-gallery-main-emoji" style="position:relative;z-index:2;font-size:120px;">🌰</span>
      {%- endif -%}
    </div>
    <div class="gallery__thumbs">
      {%- for image in product.images limit: 4 -%}
        <div class="gallery__thumb js-gallery-thumb {% if forloop.first %}active{% endif %}"
             data-src="{{ image | image_url: width: 600 }}"
             data-emoji="">
          <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | default: product.title }}" loading="lazy">
        </div>
      {%- else -%}
        <div class="gallery__thumb js-gallery-thumb active" data-emoji="🌰" data-src="">🌰</div>
        <div class="gallery__thumb js-gallery-thumb" data-emoji="🌾" data-src="">🌾</div>
        <div class="gallery__thumb js-gallery-thumb" data-emoji="🪔" data-src="">🪔</div>
        <div class="gallery__thumb js-gallery-thumb" data-emoji="📦" data-src="">📦</div>
      {%- endfor -%}
    </div>
  </div>

  <!-- Product Info -->
  <div class="product-info">
    <span class="product-cat-tag">
      {%- if product.type != blank -%}{{ product.type }}{%- else -%}Premium Makhana{%- endif -%}
    </span>

    <h1 class="product-name">{{ product.title }}</h1>

    <div class="product-rating">
      <span class="stars">⭐⭐⭐⭐⭐</span>
      <span class="rating-num">4.9</span>
      <span class="review-count" onclick="document.querySelector('[data-tab-panel=reviews]').scrollIntoView({behavior:'smooth'})">(486 reviews)</span>
    </div>

    {%- if product.description != blank -%}
      <p class="product-short-desc">{{ product.description | strip_html | truncate: 220 }}</p>
    {%- endif -%}

    <!-- Price -->
    <div class="price-display">
      <div class="price-main js-product-price">
        {{ current_variant.price | money }}
      </div>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <div class="price-per">
          <span class="js-compare-price" style="text-decoration:line-through; color: var(--text-muted); font-size:16px;">
            {{ current_variant.compare_at_price | money }}
          </span>
        </div>
        {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
        {%- assign savings_pct = savings | times: 100 | divided_by: current_variant.compare_at_price -%}
        <span class="price-saving">Save {{ savings_pct }}%</span>
      {%- endif -%}
    </div>

    <!-- Add to Cart Form -->
    <form action="/cart/add" method="post" enctype="multipart/form-data">
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id-input">

      <!-- Variants -->
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="variant-selector js-variant-group" data-option-index="{{ forloop.index }}">
            <div class="variant-label">{{ option.name }}</div>
            <div class="variant-options">
              {%- for value in option.values -%}
                {%- assign variant_for_value = product.variants | where: "option{{ forloop.index }}", value | first -%}
                <button type="button"
                        class="variant-btn js-variant-btn {% if option.selected_value == value %}active{% endif %}"
                        data-option-position="{{ forloop.index }}"
                        data-option-value="{{ value }}"
                        {% unless variant_for_value.available %}disabled{% endunless %}>
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <!-- Quantity -->
      <div class="qty-label">Quantity</div>
      <div class="qty-row">
        <div class="qty-control js-qty-control">
          <button type="button" class="qty-btn-pg js-qty-decrease" aria-label="Decrease quantity">&#8722;</button>
          <span class="qty-num-pg js-qty-num" id="qtyNum">1</span>
          <button type="button" class="qty-btn-pg js-qty-increase" aria-label="Increase quantity">&#43;</button>
          <input type="hidden" name="quantity" value="1">
        </div>
        {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 20 -%}
          <span class="qty-note">Only {{ current_variant.inventory_quantity }} left in stock</span>
        {%- endif -%}
      </div>

      <!-- CTA Buttons -->
      <div class="cta-buttons">
        <button type="submit"
                class="btn-add-cart"
                {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}
            🛒 Add to Cart — <span class="js-cart-btn-price">{{ current_variant.price | money }}</span>
          {%- else -%}
            Out of Stock
          {%- endif -%}
        </button>
        <a href="/checkout?variant={{ current_variant.id }}&quantity=1" class="btn-buy-now">
          ⚡ Buy Now
        </a>
        <button type="button" class="btn-wishlist">&#9825; Save to Wishlist</button>
      </div>
    </form>

    <!-- Trust Badges -->
    <div class="trust-badges">
      <div class="trust-badge"><span class="trust-badge-icon">🚚</span>Free delivery above ₹499</div>
      <div class="trust-badge"><span class="trust-badge-icon">🔄</span>7-day easy returns</div>
      <div class="trust-badge"><span class="trust-badge-icon">🔬</span>Lab tested every batch</div>
      <div class="trust-badge"><span class="trust-badge-icon">🌿</span>No preservatives added</div>
      <div class="trust-badge"><span class="trust-badge-icon">📋</span>FSSAI certified</div>
      <div class="trust-badge"><span class="trust-badge-icon">🌾</span>Direct from Bihar farms</div>
    </div>

    <!-- Share -->
    <div class="share-row" style="display:flex; align-items:center; gap:10px; font-size:12px; color:var(--text-muted); padding-top:16px; border-top:1px solid var(--border);">
      <span>Share:</span>
      <a href="https://wa.me/?text={{ product.title | url_encode }}%20{{ request.origin }}{{ product.url }}" target="_blank" rel="noopener" class="btn btn--outline btn--sm">📱 WhatsApp</a>
    </div>
  </div>
</div>

<!-- Product Details Tabs -->
<div class="product-details js-tabs-container">
  <div class="tabs-nav">
    <button class="tab-nav-btn js-tab-btn active" data-tab="description">Description</button>
    <button class="tab-nav-btn js-tab-btn" data-tab="nutrition">Nutrition Facts</button>
    <button class="tab-nav-btn js-tab-btn" data-tab="ingredients">Ingredients</button>
    <button class="tab-nav-btn js-tab-btn" data-tab="reviews">Reviews (486)</button>
  </div>

  <!-- Description Tab -->
  <div class="tab-panel active js-tab-panel" data-tab-panel="description">
    <div class="desc-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start;">
      <div class="desc-body">
        <h3 style="font-family:var(--font-heading); font-size:24px; font-weight:700; color:var(--brown-dark); margin-bottom:14px;">About This Product</h3>
        <div style="font-size:14px; color:var(--text-muted); line-height:1.8; font-weight:300;">
          {{ product.description }}
        </div>
      </div>
      <div class="desc-highlights" style="display:flex; flex-direction:column; gap:12px;">
        <div style="display:flex; gap:12px; align-items:flex-start;">
          <span style="font-size:20px; flex-shrink:0; margin-top:2px;">🌊</span>
          <div>
            <strong style="display:block; font-size:14px; font-weight:600; color:var(--brown-dark); margin-bottom:2px;">Single-Origin from Mithila, Bihar</strong>
            <span style="font-size:13px; color:var(--text-muted); font-weight:300;">Traceable to specific partner farms — not blended from multiple sources.</span>
          </div>
        </div>
        <div style="display:flex; gap:12px; align-items:flex-start;">
          <span style="font-size:20px; flex-shrink:0; margin-top:2px;">🥄</span>
          <div>
            <strong style="display:block; font-size:14px; font-weight:600; color:var(--brown-dark); margin-bottom:2px;">Roasted in Pure Desi Ghee</strong>
            <span style="font-size:13px; color:var(--text-muted); font-weight:300;">No refined oils. Just a touch of pure cow ghee for flavour and crunch.</span>
          </div>
        </div>
        <div style="display:flex; gap:12px; align-items:flex-start;">
          <span style="font-size:20px; flex-shrink:0; margin-top:2px;">🎯</span>
          <div>
            <strong style="display:block; font-size:14px; font-weight:600; color:var(--brown-dark); margin-bottom:2px;">Grade A Sutta Size</strong>
            <span style="font-size:13px; color:var(--text-muted); font-weight:300;">Large, round, uniform kernels — the highest grade, best crunch-to-puff ratio.</span>
          </div>
        </div>
        <div style="display:flex; gap:12px; align-items:flex-start;">
          <span style="font-size:20px; flex-shrink:0; margin-top:2px;">♻️</span>
          <div>
            <strong style="display:block; font-size:14px; font-weight:600; color:var(--brown-dark); margin-bottom:2px;">Resealable Vacuum Pouch</strong>
            <span style="font-size:13px; color:var(--text-muted); font-weight:300;">Stays fresh for 6 months unopened. Reseal after opening to keep the crunch.</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Nutrition Tab -->
  <div class="tab-panel js-tab-panel" data-tab-panel="nutrition">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start;">
      <div>
        <h3 style="font-family:var(--font-heading); font-size:20px; font-weight:700; color:var(--brown-dark); margin-bottom:6px;">Nutrition Facts</h3>
