        </table>
        <div style="font-size:11px; color:var(--text-muted); margin-top:10px; font-weight:300;">* % Daily Values based on a 2,000 calorie diet.</div>
      </div>
      <div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px;">
          <div style="background:var(--cream-2); border-radius:14px; padding:18px 16px; border:1px solid var(--border);">
            <div style="font-family:var(--font-heading); font-size:28px; font-weight:700; color:var(--green); line-height:1; margin-bottom:4px;">9.7<span style="font-size:13px; font-weight:400; color:var(--text-muted);">g</span></div>
            <div style="font-size:12px; color:var(--text-muted); font-weight:300;">Protein per 100g</div>
          </div>
          <div style="background:var(--cream-2); border-radius:14px; padding:18px 16px; border:1px solid var(--border);">
            <div style="font-family:var(--font-heading); font-size:28px; font-weight:700; color:var(--green); line-height:1; margin-bottom:4px;">347<span style="font-size:13px; font-weight:400; color:var(--text-muted);">kcal</span></div>
            <div style="font-size:12px; color:var(--text-muted); font-weight:300;">Calories per 100g</div>
          </div>
          <div style="background:var(--cream-2); border-radius:14px; padding:18px 16px; border:1px solid var(--border);">
            <div style="font-family:var(--font-heading); font-size:28px; font-weight:700; color:var(--green); line-height:1; margin-bottom:4px;">0<span style="font-size:13px; font-weight:400; color:var(--text-muted);">mg</span></div>
            <div style="font-size:12px; color:var(--text-muted); font-weight:300;">Cholesterol</div>
          </div>
          <div style="background:var(--cream-2); border-radius:14px; padding:18px 16px; border:1px solid var(--border);">
            <div style="font-family:var(--font-heading); font-size:28px; font-weight:700; color:var(--green); line-height:1; margin-bottom:4px;">Low</div>
            <div style="font-size:12px; color:var(--text-muted); font-weight:300;">Glycaemic Index</div>
          </div>
        </div>
        <div style="background:var(--green-pale); border-radius:14px; padding:18px; border:1px solid rgba(74,103,65,0.15);">
          <div style="font-size:13px; font-weight:600; color:var(--green); margin-bottom:8px;">✅ Suitable For</div>
          <div style="display:flex; flex-direction:column; gap:6px; font-size:13px; color:var(--text-mid); font-weight:300;">
            <span>• Weight loss &amp; calorie-conscious diets</span>
            <span>• Diabetic-friendly (low GI)</span>
            <span>• Gluten-free diets</span>
            <span>• Vegan &amp; vegetarian</span>
            <span>• Kids (age 3+) &amp; elderly</span>
            <span>• Post-workout snacking</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Ingredients Tab -->
  <div class="tab-panel js-tab-panel" data-tab-panel="ingredients">
    <div style="max-width:640px;">
      <h3 style="font-family:var(--font-heading); font-size:22px; font-weight:700; color:var(--brown-dark); margin-bottom:14px;">What's Inside</h3>
      <div style="background:var(--cream-2); border-radius:14px; padding:20px 22px; margin-bottom:14px; border:1px solid var(--border);">
        <p style="font-size:15px; font-weight:500; color:var(--brown-dark); margin-bottom:6px;">Fox Nuts (Euryale Ferox) — 98.5%</p>
        <span style="font-size:13px; color:var(--text-muted); font-weight:300;">Sourced exclusively from certified partner farms in Darbhanga and Madhubani, Bihar. Hand-harvested, sun-dried, and mechanically popped.</span>
      </div>
      <div style="background:var(--cream-2); border-radius:14px; padding:20px 22px; margin-bottom:14px; border:1px solid var(--border);">
        <p style="font-size:15px; font-weight:500; color:var(--brown-dark); margin-bottom:6px;">Pure Desi Ghee (Cow) — 1.5%</p>
        <span style="font-size:13px; color:var(--text-muted); font-weight:300;">Used in minimal quantities for roasting. Sourced from local dairy cooperatives in Bihar.</span>
      </div>
      <div style="background:var(--green-pale); border-radius:14px; padding:20px 22px; margin-bottom:14px; border:1px solid rgba(74,103,65,0.15);">
        <p style="font-size:15px; font-weight:500; color:var(--green); margin-bottom:6px;">✅ Contains NO:</p>
        <span style="font-size:13px; color:var(--text-muted); font-weight:300;">Artificial flavours · Artificial colours · Preservatives · Added salt · Added sugar · MSG · Palm oil · Gluten</span>
      </div>
      <div style="background:var(--gold-pale); border: 1px solid rgba(201,168,76,0.25); border-radius:10px; padding:14px 16px; display:flex; gap:10px; align-items:flex-start; margin-bottom:16px;">
        <span>⚠️</span>
        <span style="font-size:13px; color:var(--brown-mid); line-height:1.65; font-weight:300;"><strong>Allergen info:</strong> Manufactured in a facility that also processes tree nuts and dairy. May contain trace amounts.</span>
      </div>
      <div style="font-size:13px; color:var(--text-muted); line-height:1.7; font-weight:300;">
        <strong style="color:var(--brown-dark); display:block; margin-bottom:6px;">Storage Instructions</strong>
        Store in a cool, dry place away from direct sunlight. Reseal after opening. Best consumed within 45 days of opening. Do not refrigerate.
      </div>
    </div>
  </div>

  <!-- Reviews Tab -->
  <div class="tab-panel js-tab-panel" data-tab-panel="reviews">
    <div class="reviews-layout">
      <div class="reviews-summary">
        <div class="rs-big-num">4.9</div>
        <div class="rs-stars">⭐⭐⭐⭐⭐</div>
        <div class="rs-count">486 verified reviews</div>
        <div class="rating-bars">
          <div class="rating-bar-row"><span class="rating-bar-label">5★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:88%;"></div></div><span class="rating-bar-count">428</span></div>
          <div class="rating-bar-row"><span class="rating-bar-label">4★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:9%; background:var(--terra-light);"></div></div><span class="rating-bar-count">44</span></div>
          <div class="rating-bar-row"><span class="rating-bar-label">3★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:2%; background:var(--cream-3);"></div></div><span class="rating-bar-count">10</span></div>
          <div class="rating-bar-row"><span class="rating-bar-label">2★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:1%; background:var(--cream-3);"></div></div><span class="rating-bar-count">4</span></div>
          <div class="rating-bar-row"><span class="rating-bar-label">1★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:0%;"></div></div><span class="rating-bar-count">0</span></div>
        </div>
      </div>
      <div class="reviews-list">
        <div class="review-card">
          <div class="review-header">
            <div class="reviewer-info">
              <div class="reviewer-avatar" style="background:var(--terra-pale);color:var(--terra);">P</div>
              <div><div class="reviewer-name">Priya Sharma</div><div class="reviewer-meta">Mumbai · June 2026</div></div>
            </div>
            <span class="review-rating">⭐⭐⭐⭐⭐</span>
          </div>
          <div class="review-title">Best makhana I've ever had — and I've tried 8 brands</div>
          <div class="review-body">The crunch is incredible. Tal Makhana stays crispy even after a week if you reseal properly. My whole family is hooked. I've switched to the 1kg subscription now.</div>
          <span class="review-verified">✓ Verified Purchase</span>
        </div>
        <div class="review-card">
          <div class="review-header">
            <div class="reviewer-info">
              <div class="reviewer-avatar" style="background:var(--green-pale);color:var(--green);">R</div>
              <div><div class="reviewer-name">Rohit Verma</div><div class="reviewer-meta">Delhi · May 2026</div></div>
            </div>
            <span class="review-rating">⭐⭐⭐⭐⭐</span>
          </div>
          <div class="review-title">My diabetic father loves this — doctor approved!</div>
          <div class="review-body">We were looking for a safe evening snack for my father who has Type 2 diabetes. His nutritionist suggested makhana. Clean ingredient list with no hidden additives.</div>
          <span class="review-verified">✓ Verified Purchase</span>
        </div>
        <div class="review-card">
          <div class="review-header">
            <div class="reviewer-info">
              <div class="reviewer-avatar" style="background:var(--gold-pale);color:var(--brown-mid);">A</div>
              <div><div class="reviewer-name">Ananya Iyer</div><div class="reviewer-meta">Bangalore · June 2026</div></div>
            </div>
            <span class="review-rating">⭐⭐⭐⭐⭐</span>
          </div>
          <div class="review-title">Replaced my 3pm chips habit completely</div>
          <div class="review-body">I work from home and was snacking on chips every afternoon. Switched to a small bowl of Tal Makhana. It keeps me full until dinner and I don't feel guilty.</div>
          <span class="review-verified">✓ Verified Purchase</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Related Products -->
<div class="related">
  <div class="related-header">
    <div class="section__title">You Might Also <em>Like</em></div>
    <a href="/collections/all" class="products__view-all">View All →</a>
  </div>
  <div class="related-grid">
    {%- assign related_collection = collections['all'] -%}
    {%- for related_product in related_collection.products limit: 4 -%}
      {%- unless related_product.id == product.id -%}
        <a href="{{ related_product.url }}" class="related-card">
          <div class="related-img" style="background: linear-gradient(135deg, var(--cream-2), var(--cream-3));">
            {%- if related_product.featured_image -%}
              {{ related_product.featured_image | image_url: width: 300 | image_tag: alt: related_product.title, loading: 'lazy' }}
            {%- else -%}
              <span>🌰</span>
            {%- endif -%}
          </div>
          <div class="related-body">
            <div class="related-name">{{ related_product.title }}</div>
            <div class="related-from">From {{ related_product.price_min | money }}</div>
            <div class="related-price">{{ related_product.price_min | money }}</div>
          </div>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

<script>
// Expose variant data for JS selector
window.productVariants = {{ product.variants | json }};
</script>
