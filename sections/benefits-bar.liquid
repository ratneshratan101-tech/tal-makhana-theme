<div class="benefits-bar" id="benefits">
  {%- for i in (1..5) -%}
    {%- assign icon_key = 'icon_' | append: i -%}
    {%- assign text_key = 'text_' | append: i -%}
    {%- if section.settings[text_key] != blank -%}
      {%- if i > 1 -%}<div class="benefits-bar__sep" aria-hidden="true"></div>{%- endif -%}
      <div class="benefits-bar__item">
        {%- if section.settings[icon_key] != blank -%}
          <span class="benefits-bar__icon" aria-hidden="true">{{ section.settings[icon_key] }}</span>
        {%- endif -%}
        <span>{{ section.settings[text_key] }}</span>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<section class="benefits section" id="benefits-section">
  <div class="section-header text-center">
    <div class="label-pill--green label-pill">Why Tal Makhana?</div>
    <h2 class="section__title">
      {{ section.settings.section_heading | default: 'Goodness in Every Bite' }}
    </h2>
    <p class="section__desc" style="margin: 12px auto 0;">
      {{ section.settings.section_desc | default: 'Makhana is one of nature\'s most complete superfoods — and we source only the finest Grade A from Bihar\'s pristine ponds.' }}
    </p>
  </div>

  <div class="benefits__grid">
    {%- for block in section.blocks -%}
      <div class="benefit-card" {{ block.shopify_attributes }}>
        <span class="benefit-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
        <div class="benefit-card__title">{{ block.settings.title }}</div>
        <p class="benefit-card__desc">{{ block.settings.description }}</p>
      </div>
    {%- else -%}
      <div class="benefit-card">
        <span class="benefit-card__icon">💪</span>
        <div class="benefit-card__title">High in Protein</div>
        <p class="benefit-card__desc">9.7g of protein per 100g — more than most nuts. Perfect for post-workout snacking.</p>
      </div>
      <div class="benefit-card">
        <span class="benefit-card__icon">📉</span>
        <div class="benefit-card__title">Low Glycaemic Index</div>
        <p class="benefit-card__desc">Safe for diabetics and weight-watchers. Makhana won't spike your blood sugar.</p>
      </div>
      <div class="benefit-card">
        <span class="benefit-card__icon">🌿</span>
        <div class="benefit-card__title">Zero Preservatives</div>
        <p class="benefit-card__desc">No artificial colours, flavours, or preservatives. Just pure, natural makhana.</p>
      </div>
      <div class="benefit-card">
        <span class="benefit-card__icon">🔥</span>
        <div class="benefit-card__title">Only 347 Calories</div>
        <p class="benefit-card__desc">A large bowl of makhana has fewer calories than a small bag of chips. Guilt-free snacking.</p>
      </div>
      <div class="benefit-card">
        <span class="benefit-card__icon">🌾</span>
        <div class="benefit-card__title">Gluten-Free</div>
        <p class="benefit-card__desc">Naturally gluten-free and suitable for celiac diets. Safe for the whole family.</p>
      </div>
      <div class="benefit-card">
        <span class="benefit-card__icon">🧘</span>
        <div class="benefit-card__title">Ayurvedic Superfood</div>
        <p class="benefit-card__desc">Mentioned in ancient Ayurvedic texts as a sattvic food that promotes calm and longevity.</p>
      </div>
    {%- endfor -%}
  </div>
</section>

