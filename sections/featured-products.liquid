{%- assign collection = collections[section.settings.collection] -%}
{%- assign products_to_show = section.settings.products_to_show | default: 6 -%}

<section class="products-section {% if section.settings.dark_bg %}products-section--cream{% endif %}">
  <div class="products__header">
    <div>
      {%- if section.settings.section_label != blank -%}
        <div class="label-pill">{{ section.settings.section_label }}</div>
      {%- endif -%}
      <h2 class="section__title">
        {{ section.settings.heading | default: 'Our Products' }}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="section__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    {%- if collection != blank -%}
      <a href="{{ collection.url }}" class="products__view-all">View All →</a>
    {%- else -%}
      <a href="/collections/all" class="products__view-all">View All →</a>
    {%- endif -%}
  </div>

  <div class="products__grid">
    {%- if collection != blank and collection.products.size > 0 -%}
      {%- for product in collection.products limit: products_to_show -%}
        <a href="{{ product.url }}" class="product-card">
          <div class="product-card__img"
               style="background: linear-gradient(135deg, var(--cream-2), var(--cream-3));">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 400 | image_tag:
                alt: product.featured_image.alt,
                loading: 'lazy',
                class: 'product-card__featured-img' }}
            {%- else -%}
              <span>🌰</span>
            {%- endif -%}
            <div class="product-card__badges">
              {%- if product.tags contains 'bestseller' -%}
                <span class="product-card__badge product-card__badge--bestseller">Bestseller</span>
              {%- endif -%}
              {%- if product.tags contains 'new' -%}
                <span class="product-card__badge product-card__badge--new">New</span>
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                {%- assign savings = product.compare_at_price | minus: product.price -%}
                {%- assign savings_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
                <span class="product-card__badge product-card__badge--sale">{{ savings_pct }}% off</span>
              {%- endif -%}
            </div>
            <button class="product-card__quick-add" aria-label="Quick add {{ product.title }}"
                    onclick="event.preventDefault(); window.TalMakhana && TalMakhana.cart.add({{ product.variants.first.id }}, 1);">
              + Add to Cart
            </button>
          </div>
          <div class="product-card__body">
            <h3 class="product-card__title">{{ product.title }}</h3>
            {%- if product.description != blank -%}
              <p class="product-card__desc">{{ product.description | strip_html }}</p>
            {%- endif -%}
            <div class="product-card__footer">
              <div>
                <span class="product-card__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="product-card__compare-price">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                {%- if product.variants.size > 1 -%}
                  <div class="product-card__from">Multiple sizes</div>
                {%- endif -%}
              </div>
              {%- if product.compare_at_price > product.price -%}
                {%- assign savings = product.compare_at_price | minus: product.price -%}
                {%- assign savings_pct = savings | times: 100 | divided_by: product.compare_at_price -%}
                <span class="product-card__savings">{{ savings_pct }}% off</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      <!-- Placeholder cards when no collection is set -->
      {%- assign placeholder_products = "Plain Roasted,Himalayan Salt,Peri Peri,Butter & Herbs,Gift Pack,Family Pack" | split: "," -%}
      {%- assign placeholder_emojis = "🌰,🧂,🌶️,🧈,🎁,📦" | split: "," -%}
      {%- assign placeholder_prices = "From ₹199,From ₹219,From ₹229,From ₹239,₹799,₹1399" | split: "," -%}
      {%- for name in placeholder_products -%}
        {%- assign idx = forloop.index0 -%}
        <div class="product-card" style="cursor:default;">
          <div class="product-card__img" style="background: linear-gradient(135deg, var(--cream-2), var(--cream-3));">
            <span>{{ placeholder_emojis[idx] }}</span>
            {%- if forloop.index == 1 or forloop.index == 2 -%}
              <div class="product-card__badges">
                {%- if forloop.index == 1 -%}
                  <span class="product-card__badge product-card__badge--bestseller">Bestseller</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
          <div class="product-card__body">
            <h3 class="product-card__title">{{ name }}</h3>
            <p class="product-card__desc">Premium hand-harvested makhana from Bihar. Grade A quality, no preservatives.</p>
            <div class="product-card__footer">
              <span class="product-card__price">{{ placeholder_prices[idx] }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label (pill above heading)",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Crafted for the Health-Conscious"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Six flavours, one standard — Bihar's finest. Each batch is hand-selected, lab-tested, and packed fresh."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "dark_bg",
      "label": "Cream background",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
