<section class="section youtube-section" style="background: var(--brown-dark);">
  <div style="max-width: 900px; margin: 0 auto;">
    <!-- Channel Strip -->
    <div style="display:flex; align-items:center; gap:20px; margin-bottom: 40px; flex-wrap:wrap;">
      <div style="display:flex; align-items:center; gap:12px;">
        <div style="width:44px; height:44px; background: #FF0000; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px; color:white; font-weight:700; flex-shrink:0;">▶</div>
        <div>
          <div style="font-size:15px; font-weight:600; color: var(--white);">{{ section.settings.channel_name | default: 'Tal Makhana' }}</div>
          <div style="font-size:12px; color: rgba(255,255,255,0.4);">{{ section.settings.channel_handle | default: '@talmakhana · YouTube' }}</div>
        </div>
      </div>
      <div style="display:flex; gap:24px; margin-left:auto; flex-wrap:wrap;">
        <div style="text-align:center;">
          <div style="font-family: var(--font-heading); font-size:20px; font-weight:700; color:var(--white); line-height:1;">{{ section.settings.subscriber_count | default: '48K' }}</div>
          <div style="font-size:11px; color:rgba(255,255,255,0.4);">Subscribers</div>
        </div>
        <div style="text-align:center;">
          <div style="font-family: var(--font-heading); font-size:20px; font-weight:700; color:var(--white); line-height:1;">{{ section.settings.video_count | default: '120+' }}</div>
          <div style="font-size:11px; color:rgba(255,255,255,0.4);">Videos</div>
        </div>
        <div style="text-align:center;">
          <div style="font-family: var(--font-heading); font-size:20px; font-weight:700; color:var(--white); line-height:1;">{{ section.settings.view_count | default: '2.4M' }}</div>
          <div style="font-size:11px; color:rgba(255,255,255,0.4);">Total Views</div>
        </div>
      </div>
      <a href="{{ section.settings.channel_url | default: 'https://youtube.com/@talmakhana' }}" target="_blank" rel="noopener"
         style="background:#FF0000; color:white; display:inline-flex; align-items:center; gap:8px; font-size:14px; font-weight:600; padding:10px 24px; border-radius:100px; text-decoration:none; white-space:nowrap; transition: background 0.2s;">
        ▶ Subscribe Free
      </a>
    </div>

    <!-- Section Label -->
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
      <span class="label-pill">{{ section.settings.label | default: 'Latest Video' }}</span>
      <div style="flex:1; height:1px; background:rgba(255,255,255,0.08);"></div>
    </div>

    <!-- Featured Video -->
    {%- if section.settings.youtube_url != blank -%}
      {%- assign video_id = section.settings.youtube_url | split: 'v=' | last | split: '&' | first -%}
      {%- if section.settings.youtube_url contains 'youtu.be/' -%}
        {%- assign video_id = section.settings.youtube_url | split: 'youtu.be/' | last | split: '?' | first -%}
      {%- endif -%}
      <div class="video-embed-wrap" style="border-radius: 20px; overflow:hidden; margin-bottom:40px;">
        <iframe
          src="https://www.youtube.com/embed/{{ video_id }}?rel=0&modestbranding=1"
          title="{{ section.settings.video_title | default: 'Tal Makhana Recipe Video' }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy">
        </iframe>
      </div>
    {%- else -%}
      <!-- Placeholder when no YouTube URL is set -->
      <div style="background: linear-gradient(135deg, #1A3A2A, #2E5C42); border-radius:20px; min-height:340px; display:flex; align-items:center; justify-content:center; margin-bottom:40px; position:relative; overflow:hidden; cursor:pointer;">
        <div style="position:absolute; inset:0; background:rgba(0,0,0,0.35);"></div>
        <div style="position:relative; z-index:2; text-align:center;">
          <div style="width:80px; height:80px; background:rgba(255,255,255,0.95); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:32px; margin:0 auto 16px; padding-left:6px;">▶</div>
          <div style="color:white; font-size:18px; font-weight:600;">{{ section.settings.video_title | default: 'Watch on YouTube' }}</div>
          <div style="color:rgba(255,255,255,0.6); font-size:13px; margin-top:6px;">Set a YouTube URL in theme customizer</div>
        </div>
      </div>
    {%- endif -%}

    <!-- Subscribe Banner -->
    <div style="text-align:center; padding:20px 0;">
      <h2 style="font-family: var(--font-heading); font-size: clamp(22px, 3vw, 32px); font-weight:700; color:white; margin-bottom:12px;">
        {{ section.settings.cta_heading | default: 'Never Miss a New Recipe' }}
      </h2>
      <p style="font-size:14px; color:rgba(255,255,255,0.5); max-width:500px; margin: 0 auto 24px; font-weight:300; line-height:1.7;">
        {{ section.settings.cta_desc | default: 'New makhana recipes and health videos every week. Subscribe free.' }}
      </p>
      <a href="{{ section.settings.channel_url | default: 'https://youtube.com/@talmakhana' }}"
         target="_blank" rel="noopener"
         style="display:inline-flex; align-items:center; gap:10px; background:white; color:#FF0000; font-size:15px; font-weight:700; padding:14px 32px; border-radius:100px; text-decoration:none;">
        ▶ Subscribe on YouTube
      </a>
      {%- if section.settings.subscriber_count != blank -%}
        <div style="font-size:12px; color:rgba(255,255,255,0.4); margin-top:12px;">
          {{ section.settings.subscriber_count }} subscribers already
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "YouTube Preview",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Latest Video"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube Video URL",
      "info": "Paste a YouTube video URL (e.g. https://www.youtube.com/watch?v=XXXXX)"
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Video Title",
      "default": "Makhana Kheer — Creamy Indian Dessert in 15 Minutes"
    },
    {
      "type": "text",
      "id": "channel_name",
      "label": "Channel Name",
      "default": "Tal Makhana"
    },
    {
      "type": "text",
      "id": "channel_handle",
      "label": "Channel Handle",
      "default": "@talmakhana · YouTube"
    },
    {
      "type": "url",
      "id": "channel_url",
      "label": "YouTube Channel URL"
    },
    {
      "type": "text",
      "id": "subscriber_count",
      "label": "Subscriber Count (display)",
      "default": "48K"
    },
    {
      "type": "text",
      "id": "video_count",
      "label": "Video Count (display)",
      "default": "120+"
    },
    {
      "type": "text",
      "id": "view_count",
      "label": "Total Views (display)",
      "default": "2.4M"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Never Miss a New Recipe"
    },
    {
      "type": "textarea",
      "id": "cta_desc",
      "label": "CTA Description",
      "default": "New makhana recipes and health videos every week. Subscribe free and hit the bell."
    }
  ],
  "presets": [
    {
      "name": "YouTube Preview"
    }
  ]
}
{% endschema %}
